# ── Shared Supabase (same project as luveni2.0 storefront) ──
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=__service_role_key__

# ── LLM brain (provider-agnostic; pick one) ──
# OpenRouter (DEFAULT) — free-tier models so the fleet never spends credits.
# Get a key at https://openrouter.ai/keys. ":free" models cost $0.
LLM_PROVIDER=openrouter
LLM_MODEL=deepseek/deepseek-chat-v3-0324:free
# Optional: comma-separated models to roll over to on a 429 rate-limit,
# ordered most→least preferred.
LLM_MODEL_FALLBACKS=meta-llama/llama-3.3-70b-instruct:free,google/gemini-2.0-flash-exp:free,qwen/qwen-2.5-72b-instruct:free
OPENROUTER_API_KEY=
# Anthropic (paid fallback) — set LLM_PROVIDER=anthropic to use.
ANTHROPIC_API_KEY=
# Gemini fallback (free tier) — set LLM_PROVIDER=gemini to use.
GEMINI_API_KEY=

# ── Astra realtime voice (LiveKit) ──
LIVEKIT_URL=wss://YOUR.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
ASTRA_TOKEN_PORT=8787

# ── Orchestrator ──
# Comma-separated agent ids to run in this process (default: all).
FLEET_AGENTS=
POLL_INTERVAL_MS=5000
