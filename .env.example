# ── Shared Supabase (same project as luveni2.0 storefront) ──
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=__service_role_key__

# ── LLM brain (provider-agnostic; pick one) ──
# Anthropic (default). Latest capable model id, e.g. claude-sonnet-5.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-5
ANTHROPIC_API_KEY=
# Gemini fallback (free tier) — set LLM_PROVIDER=gemini to use.
GEMINI_API_KEY=

# ── Astra realtime voice (LiveKit) ──
LIVEKIT_URL=wss://YOUR.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
ASTRA_TOKEN_PORT=8787

# ── Orchestrator ──
# Comma-separated agent ids to run in this process (default: all).
FLEET_AGENTS=
POLL_INTERVAL_MS=5000
